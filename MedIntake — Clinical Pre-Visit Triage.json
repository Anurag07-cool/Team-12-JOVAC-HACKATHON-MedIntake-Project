        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"extracted_data\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"chief_complaint\": { \"type\": \"string\" },\n        \"symptom_duration\": { \"type\": \"string\" },\n        \"severity\": { \"type\": \"string\", \"enum\": [\"Mild\", \"Moderate\", \"Severe\", \"Unknown\"] },\n        \"medications\": { \"type\": \"array\", \"items\": { \"type\": \"string\" } },\n        \"allergies\": { \"type\": \"array\", \"items\": { \"type\": \"string\" } }\n      },\n      \"required\": [\"chief_complaint\", \"symptom_duration\", \"severity\", \"medications\", \"allergies\"]\n    },\n    \"validation\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"status\": { \"type\": \"string\", \"enum\": [\"Valid\", \"Needs Nurse Review\"] },\n        \"review_reason\": { \"type\": [\"string\", \"null\"] }\n      },\n      \"required\": [\"status\", \"review_reason\"]\n    }\n  },\n  \"required\": [\"extracted_data\", \"validation\"]\n}"
      },
